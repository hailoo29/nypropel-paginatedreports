	'vBallInCourt'[Due Date],
	'vBallInCourt'[Final Due Date],
	'vBallInCourt'[Name],
	'vBallInCourt'[Ball in Court]</CommandText>
      </Query>
      <Fields>
        <Field Name="vBallInCourt_Tool">
          <DataField>vBallInCourt[Tool]</DataField>
        </Field>
        <Field Name="vBallInCourt_Number">
          <DataField>vBallInCourt[Number]</DataField>
        </Field>
        <Field Name="vBallInCourt_Revision">
          <DataField>vBallInCourt[Revision]</DataField>
        </Field>
        <Field Name="vBallInCourt_Due_20_Date">
          <DataField>vBallInCourt[Due Date]</DataField>
        </Field>
        <Field Name="vBallInCourt_Reviewer_20_Due_20_Date">
          <DataField>vBallInCourt[Reviewer's Due Date]</DataField>
        </Field>
        <Field Name="vBallInCourt_Final_20_Due_20_Date">
          <DataField>vBallInCourt[Final Due Date]</DataField>
        </Field>
        <Field Name="vBallInCourt_Name">
          <DataField>vBallInCourt[Name]</DataField>
        </Field>
        <Field Name="vBallInCourt_Ball_20_in_20_Court">
          <DataField>vBallInCourt[Ball in Court]</DataField>
        </Field>
        <Field Name="vBallInCourt_vDaysLate">
          <DataField>vBallInCourt[vDaystoDueDate]</DataField>
        </Field>
        <Field Name="vBallInCourt_URL">
          <DataField>vBallInCourt[URL]</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_Draft">
      <Query>
        <DataSourceName>ProcoreProjectManagement20Custom</DataSourceName>
        <CommandText>DEFINE
	VAR __DS0FilterTable = 
		FILTER(
			KEEPFILTERS(VALUES('Project'[Project Name])),
			NOT(
				'Project'[Project Name] IN {"Brandon",
					"INTERNAL ONLY - PROCORE TESTING",
					"Location Site Project Template",
					"Placeholder",
					"Sandbox Test Project",
					"Standard Project Template"}
			)
		)

	VAR __DS0FilterTable2 = 
		FILTER(
			KEEPFILTERS(VALUES('vBallInCourt'[Ball in Court])),
			NOT(ISBLANK('vBallInCourt'[Ball in Court]))
		)

	VAR __DS0FilterTable3 = 
		TREATAS({"Draft"}, 'vBallInCourt'[Status])

	VAR __DS0FilterTable4 = 
		FILTER(KEEPFILTERS(VALUES('vBallInCourt'[Number])), TRUE())

	VAR __DS0Core = 
		SUMMARIZECOLUMNS(
			'vBallInCourt'[vDOMGroup],
			'vBallInCourt'[Tool],
			'vBallInCourt'[Number],
			'vBallInCourt'[Revision],
			'vBallInCourt'[Due Date],
			'vBallInCourt'[Reviewer's Due Date],
			'vBallInCourt'[Final Due Date],
			'vBallInCourt'[vDaystoDueDate],
			'vBallInCourt'[Name],
			'vBallInCourt'[Ball in Court],
			'vBallInCourt'[URL],
			__DS0FilterTable,
			__DS0FilterTable2,
			__DS0FilterTable3,
			__DS0FilterTable4,
			"SumvDaysLate", CALCULATE(SUM('vBallInCourt'[vDaysLate]))
		)

EVALUATE
	__DS0Core

ORDER BY
	'vBallInCourt'[vDOMGroup],
	'vBallInCourt'[Tool],
	'vBallInCourt'[Number],
	'vBallInCourt'[Revision],
	'vBallInCourt'[Due Date],
	'vBallInCourt'[Final Due Date],
	'vBallInCourt'[Name],
	'vBallInCourt'[Ball in Court]</CommandText>
      </Query>
      <Fields>
        <Field Name="vBallInCourt_Tool">
          <DataField>vBallInCourt[Tool]</DataField>
        </Field>
        <Field Name="vBallInCourt_Number">
          <DataField>vBallInCourt[Number]</DataField>
        </Field>
        <Field Name="vBallInCourt_Revision">
          <DataField>vBallInCourt[Revision]</DataField>
        </Field>
        <Field Name="vBallInCourt_Due_20_Date">
          <DataField>vBallInCourt[Due Date]</DataField>
        </Field>
        <Field Name="vBallInCourt_Reviewer_20_Due_20_Date">
          <DataField>vBallInCourt[Reviewer's Due Date]</DataField>
        </Field>
        <Field Name="vBallInCourt_Final_20_Due_20_Date">
          <DataField>vBallInCourt[Final Due Date]</DataField>
        </Field>
        <Field Name="vBallInCourt_Name">
          <DataField>vBallInCourt[Name]</DataField>
        </Field>
        <Field Name="vBallInCourt_Ball_20_in_20_Court">
          <DataField>vBallInCourt[Ball in Court]</DataField>
        </Field>
        <Field Name="vBallInCourt_vDaysLate">
          <DataField>vBallInCourt[vDaystoDueDate]</DataField>
        </Field>
        <Field Name="vBallInCourt_URL">
          <DataField>vBallInCourt[URL]</DataField>
        </Field>
      </Fields>
    </DataSet>
